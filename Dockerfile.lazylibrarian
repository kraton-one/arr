FROM lscr.io/linuxserver/lazylibrarian:latest

# Install Calibre so LazyLibrarian can use calibredb for content-server integration.
RUN apt-get update \
    && apt-get install -y --no-install-recommends calibre unrar libunrar-dev \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* \
    && pip3 install --no-cache-dir unrar

ENV UNRAR_LIB_PATH=/usr/lib/x86_64-linux-gnu/libunrar.so
