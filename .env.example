# User/Group IDs and Timezone
PUID=1000
PGID=1000
TZ=America/New_York

# Storage Paths
# Update these to match your storage location
CONFIG_ROOT=/path/to/configs
MEDIA_ROOT=/path/to/media

# Network Configuration
LAN_SUBNETS=192.168.1.0/24
NETWORK_INTERFACE=eth0

HOST_IP=192.168.1.100
FIREWALL_INBOUND_SUBNETS=192.168.1.0/24,172.28.0.0/16

# Tdarr Configuration
TDARR_SERVER_IP=192.168.1.100
TDARR_SERVER_PORT=8266
TDARR_CACHE_ROOT=/path/to/transcode_cache
TDARR_NODE_NAME=tdarr-node-1
TDARR_NODE_IP=0.0.0.0
TDARR_NODE_PORT=8267

# ProtonVPN WireGuard Configuration
# Get these from: ProtonVPN Account → OpenVPN/WireGuard credentials
WIREGUARD_PRIVATE_KEY=your_wireguard_private_key_here
WIREGUARD_ADDRESSES=10.2.0.2/32

# Domain Configuration
# Your domain name (without subdomain)
DOMAIN=yourdomain.com

# Cloudflare Configuration (for SSL certificates)
LETSENCRYPT_EMAIL=your-email@example.com
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# qBittorrent Credentials
QBITTORRENT_USER=admin
QBITTORRENT_PASS=your_secure_password_here

# API Keys (obtain from each service after initial setup)
# SABnzbd: Config → General → API Key
SABNZBD_API_KEY=your_sabnzbd_api_key_here

# Jellyfin: Dashboard → API Keys → Create new key
JELLYFIN_API_KEY=your_jellyfin_api_key_here

# Audiobookshelf: Settings → API Keys → New API Key
AUDIOBOOKSHELF_API_KEY=your_audiobookshelf_api_key_here

# Seerr: Settings → General → API Key
SEERR_API_KEY=your_seerr_api_key_here

# Sonarr: Settings → General → Security → API Key
SONARR_API_KEY=your_sonarr_api_key_here

# Radarr: Settings → General → Security → API Key
RADARR_API_KEY=your_radarr_api_key_here

# Lidarr: Settings → General → Security → API Key
LIDARR_API_KEY=your_lidarr_api_key_here

# Bazarr: Settings → General → Security → API Key
BAZARR_API_KEY=your_bazarr_api_key_here

# Prowlarr: Settings → General → Security → API Key
PROWLARR_API_KEY=your_prowlarr_api_key_here

# Notifiarr: Get from https://notifiarr.com
NOTIFIARR_API_KEY=your_notifiarr_api_key_here

# Seedbox SFTP Configuration (for rclone sync)
SEEDBOX_HOST=your_seedbox_hostname
SEEDBOX_PORT=22
SEEDBOX_USER=your_seedbox_username
SEEDBOX_PASS=your_seedbox_password
SEEDBOX_REMOTE_PATH=/home/user/torrents/qbittorrent/downloads/complete/
